---
layout: layouts/base.njk
title: Roster
---

<div class="page">

<div class="roster-masthead">
  <div>
    <div class="roster-hed">Cat Platoon<br><span>Roster</span></div>
    <div class="roster-stamp">Sensitive — Contact Info Redacted</div>
  </div>
  <div class="roster-deck">Compiled from unit records, the McGrew field calendar, ASA newsletters, and ongoing contact research. Research status indicates current confidence level.</div>
</div>

<table class="rtable">
  <thead>
    <tr>
      <th>Name</th>
      <th>Known As</th>
      <th>Rank</th>
      <th>Platoon</th>
      <th>Service Dates</th>
      <th>Source</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>

    {# ── Confirmed profiles from data files ── #}
    {% for soldier in collections.soldiers | sort(false, false, 'name') %}
    <tr class="has-profile" onclick="window.location='/soldiers/{{ soldier.slug }}/'">
      <td><div class="rname rname-link">{{ soldier.name | replace(r/(\w+)$/, '') }}{{ soldier.name.split(' ') | last }}</div></td>
      <td>
        {% if soldier.nickname %}
          <span style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--dim);">"{{ soldier.nickname }}"</span>
        {% else %}
          <span style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--rule);">—</span>
        {% endif %}
      </td>
      <td><span class="rank-tag">{{ soldier.rank }} {{ soldier.grade }}</span></td>
      <td>{{ soldier.platoon }}</td>
      <td style="font-family:'Space Grotesk',sans-serif;font-size:11px;letter-spacing:1px;">{{ soldier.arrived | truncate(8, true, '') }} – {{ soldier.departed | truncate(8, true, '') }}</td>
      <td>DD-214, Family</td>
      <td><span class="sdot sdot-ok">Confirmed — Profile Live</span></td>
    </tr>
    {% endfor %}

    {# ── Known soldiers without profiles yet ── #}
