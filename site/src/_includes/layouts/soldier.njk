---
layout: layouts/base.njk
---

{# ── Breadcrumb ── #}
<div class="breadcrumb">
  <a class="bc-link" href="/">Archive</a>
  <span class="bc-sep">›</span>
  <a class="bc-link" href="/roster/">Roster</a>
  <span class="bc-sep">›</span>
  <span>{{ soldier.rank }} {{ soldier.name }}</span>
</div>

<div class="page">

{# ── Profile Hero ── #}
<div class="prof-hero">
  <div class="prof-photo-col">
    <div class="prof-photo-frame">
      {% if soldier.profile_photo %}
        <img src="/soldiers/{{ soldier.slug }}/{{ soldier.profile_photo }}"
             alt="{{ soldier.name }}"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div class="prof-photo-placeholder" style="display:none;">
          {{ soldier.name | truncate(3, true, '') | upper }}
        </div>
      {% else %}
        <div class="prof-photo-placeholder">
          {{ soldier.name | truncate(3, true, '') | upper }}
        </div>
      {% endif %}
    </div>
    <div class="prof-photo-cap">Then &amp; Now</div>
  </div>

  <div class="prof-info">
    {% if soldier.status === 'deceased' %}
      <div class="prof-deceased">Deceased{% if soldier.deceased_year %} · {{ soldier.deceased_year }}{% endif %}</div>
    {% elif soldier.status === 'kia' %}
      <div class="prof-deceased" style="background:#5a0a0a;">Killed in Action</div>
    {% endif %}

    <div class="prof-name">{{ soldier.name | replace(" ", "<br>") | safe }}</div>
    <div class="prof-rank">{{ soldier.rank_full }} · {{ soldier.grade }} &nbsp;·&nbsp; {{ soldier.mos_title }} ({{ soldier.mos }})</div>

    {% if soldier.nickname %}
      <div class="prof-nickname">Known as <span class="prof-nickname-val">"{{ soldier.nickname }}"</span></div>
    {% else %}
      <div class="prof-nickname" style="opacity:0.3;">Nickname unknown — can you help?</div>
    {% endif %}

    <div class="prof-grid">
      <div class="pg-item"><div class="pg-label">Platoon</div><div class="pg-value">{{ soldier.platoon }}</div></div>
      <div class="pg-item"><div class="pg-label">In-Country Service</div><div class="pg-value">{{ soldier.arrived }} – {{ soldier.departed }}</div></div>
      <div class="pg-item"><div class="pg-label">Home of Record</div><div class="pg-value">{{ soldier.hometown }}</div></div>
      <div class="pg-item"><div class="pg-label">Character of Service</div><div class="pg-value">{{ soldier.service_character }}</div></div>
    </div>

    {% if soldier.decorations and soldier.decorations.length %}
      <div class="prof-medals-label">Decorations &amp; Awards</div>
      <div class="prof-medals">
        {% for dec in soldier.decorations %}
          <span class="pmed{% if not dec.distinguished %} dim{% endif %}">{{ dec.name }}</span>
        {% endfor %}
      </div>
    {% endif %}

    <div class="prof-actions">
      <a href="/contribute/" class="prof-btn prof-btn-primary">Share a Memory</a>
      <a href="/contribute/" class="prof-btn prof-btn-ghost">Submit a Photo</a>
    </div>
  </div>
</div>

{# ── Timeline ── #}
{% if soldier.timeline and soldier.timeline.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Service Timeline</div>
    <div class="section-rule"></div>
    <div class="section-meta">{{ soldier.arrived }} – {{ soldier.departed }}</div>
  </div>

  {% if soldier.archive_notes %}
    <p style="font-family:'Crimson Pro',serif;font-style:italic;font-size:16px;color:var(--dim);margin-bottom:32px;max-width:640px;line-height:1.8;">{{ soldier.archive_notes }}</p>
  {% endif %}

  <div class="tl">
    {% for entry in soldier.timeline %}
    <div class="tl-entry">
      <div class="tl-dot {{ entry.type }}"></div>
      <div class="tl-date">{{ entry.date }}</div>

      {% if entry.type === 'combat' %}
        <span class="tl-tag tl-tag-c">Combat Action</span>
      {% elif entry.type === 'movement' %}
        <span class="tl-tag tl-tag-m">{{ 'Arrival' if loop.first else 'Movement' }}</span>
      {% elif entry.type === 'personal' %}
        <span class="tl-tag tl-tag-p">Personal</span>
      {% endif %}

      <div class="tl-hed">{{ entry.title }}</div>
      <div class="tl-body">{{ entry.body }}</div>

      {% if entry.source_notice %}
        <div class="source-notice">
          <div class="sn-head">⚠ Source Notice — Multiple Accounts Exist</div>
          <div class="sn-body">{{ entry.source_notice }}</div>
        </div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── Photo Gallery ── #}
{% if soldier.photos and soldier.photos.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Photographs</div>
    <div class="section-rule"></div>
    <div class="section-meta">{{ soldier.photos.length }} Images</div>
  </div>

  <p style="font-family:'Crimson Pro',serif;font-style:italic;font-size:16px;color:var(--dim);margin-bottom:28px;max-width:600px;line-height:1.8;">
    {{ soldier.name.split(' ')[0] }} carried a camera throughout his tour. Except where noted, every photograph here was taken by him — a first-person visual record of what he witnessed and found worth preserving.
  </p>

  {% set by_subject = [] %}
  {% set of_subject = [] %}
  {% for photo in soldier.photos %}
    {% if photo.by_subject %}
      {% set by_subject = (by_subject.push(photo), by_subject) %}
    {% else %}
      {% set of_subject = (of_subject.push(photo), of_subject) %}
    {% endif %}
  {% endfor %}

  {% if by_subject.length %}
    <div class="gallery-sublabel">Through His Eyes — Photographs He Took</div>
    <div class="photo-grid">
      {% for photo in by_subject %}
        <div class="photo-card{% if photo.wide %} wide{% endif %}"
             onclick="lb('/soldiers/{{ soldier.slug }}/{{ photo.file }}','{{ photo.caption | replace("'","\'") }}','{{ photo.credit | replace("'","\'") }}')">
          <img src="/soldiers/{{ soldier.slug }}/{{ photo.file }}" alt="{{ photo.caption | truncate(60) }}">
          <div class="photo-overlay">
            <div class="photo-cap-text">{{ photo.caption | truncate(80) }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <div class="content-notice">
    <div>
      <strong>Note on Wartime Content</strong>
      <p>This gallery includes photographs taken in a combat zone. Some images depict the realities of war. They are preserved here as historical documentation.</p>
    </div>
  </div>

  {% if of_subject.length %}
    <div class="gallery-sublabel">Among His Brothers — Photographs Others Took of {{ soldier.name.split(' ')[0] }}</div>
    <div class="photo-grid">
      {% for photo in of_subject %}
        <div class="photo-card{% if photo.wide %} wide{% endif %}"
             onclick="lb('/soldiers/{{ soldier.slug }}/{{ photo.file }}','{{ photo.caption | replace("'","\'") }}','{{ photo.credit | replace("'","\'") }}')">
          <img src="/soldiers/{{ soldier.slug }}/{{ photo.file }}" alt="{{ photo.caption | truncate(60) }}">
          <div class="photo-overlay">
            <div class="photo-cap-text">{{ photo.caption | truncate(80) }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>
{% endif %}

{# ── Documents ── #}
{% if soldier.documents and soldier.documents.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Documents &amp; Records</div>
    <div class="section-rule"></div>
  </div>
  <div class="doc-list">
    {% for doc in soldier.documents %}
      <div class="doc-item">
        <div class="doc-icon">
          {% if doc.type === 'Official' %}📋
          {% elif doc.type === 'Press' %}📰
          {% elif doc.type === 'Personal' %}✉️
          {% else %}📝{% endif %}
        </div>
        <div style="flex:1;">
          <div class="doc-title">{{ doc.title }}{% if doc.restricted %} <span style="font-size:9px;letter-spacing:2px;font-family:'Space Grotesk',sans-serif;color:var(--dim);">· Admin Only</span>{% endif %}</div>
          <div class="doc-meta">{{ doc.meta }}</div>
          {% if doc.quote %}
            <div class="doc-quote">"{{ doc.quote }}" — {{ doc.quote_attr }}</div>
          {% endif %}
        </div>
        <div class="doc-type">{{ doc.type }}</div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── Brothers ── #}
{% if soldier.brothers and soldier.brothers.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">{{ soldier.platoon }} · Served Alongside</div>
    <div class="section-rule"></div>
  </div>
  <div class="bros-grid">
    {% for bro in soldier.brothers %}
      <div class="bro-card">
        <div class="bro-circle {% if bro.status === 'deceased' or bro.status === 'kia' %}kia{% elif bro.status === 'contributor' %}contrib{% elif bro.status === 'this' %}this{% endif %}">
          <span class="bro-init {% if bro.status === 'deceased' or bro.status === 'kia' %}kia{% endif %}">{{ bro.initials }}</span>
        </div>
        <div class="bro-name">{{ bro.name }}</div>
        <div class="bro-detail">{{ bro.platoon }} · {{ bro.dates }}</div>
        <div class="bro-detail {% if bro.status === 'deceased' or bro.status === 'kia' %}kia{% elif bro.status === 'contributor' %}contrib{% endif %}">
          {% if bro.status === 'deceased' %}Deceased
          {% elif bro.status === 'kia' %}KIA
          {% elif bro.status === 'contributor' %}Archive Contributor
          {% elif bro.status === 'this' %}Deceased · This Profile
          {% else %}{{ bro.status }}{% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
  <div style="margin-top:20px;">
    <a class="tl-link" href="/roster/">View full roster</a>
  </div>
</div>
{% endif %}

{# ── Contribute CTA ── #}
<div class="prof-cta">
  <div>
    <h3>Did You Know {{ soldier.name.split(' ')[0] }}, or Serve Alongside Him?</h3>
    <p>We are actively collecting photographs, letters, and memories for this profile. Submissions are reviewed before publication. If you served with {{ soldier.name.split(' ')[0] }} — or are a family member with materials — we'd be grateful to hear from you.</p>
  </div>
  <div class="prof-cta-btns">
    <a href="/contribute/" class="btn-cta">Submit Materials</a>
  </div>
</div>

</div><!-- /page -->
