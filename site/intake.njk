---
layout: base.njk
title: Start a Profile
permalink: /intake/
---

<div class="contrib-hed">
  <div class="contrib-title">Start a<br><span>Soldier Profile</span></div>
  <div class="contrib-deck">Tell us about your soldier and what materials you have. Takes about ten minutes. We'll follow up within a few days.</div>
</div>

<div style="background: var(--pg); padding: 48px;">
<div style="max-width: 780px; margin: 0 auto;">

  <form name="profile-intake" method="POST" action="https://formspree.io/f/xbdwjrkn">
    <p style="display:none;"><label>Don't fill this out: <input name="bot-field"></label></p>

    {# ── SOLDIER IDENTITY ── #}
    <div class="contrib-panel-hed" style="margin-bottom: 20px;">About the Soldier</div>

    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0 16px;">
      <div class="fg"><label>First Name</label><input type="text" name="first_name" placeholder="First name" required></div>
      <div class="fg"><label>Middle Name</label><input type="text" name="middle_name" placeholder="Middle name or initial"></div>
      <div class="fg"><label>Last Name</label><input type="text" name="last_name" placeholder="Last name" required></div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 16px;">
      <div class="fg">
        <label>Rank (if known)</label>
        <select name="rank">
          <option value="">Unknown / Not sure</option>
          <option>Private (PVT / E-1)</option>
          <option>Private Second Class (PV2 / E-2)</option>
          <option>Private First Class (PFC / E-3)</option>
          <option>Specialist (SPC / E-4)</option>
          <option>Corporal (CPL / E-4)</option>
          <option>Sergeant (SGT / E-5)</option>
          <option>Staff Sergeant (SSG / E-6)</option>
          <option>Sergeant First Class (SFC / E-7)</option>
          <option>Master Sergeant (MSG / E-8)</option>
          <option>First Sergeant (1SG / E-8)</option>
          <option>Sergeant Major (SGM / E-9)</option>
          <option>Second Lieutenant (2LT / O-1)</option>
          <option>First Lieutenant (1LT / O-2)</option>
          <option>Captain (CPT / O-3)</option>
          <option>Other / Unknown officer</option>
        </select>
      </div>
      <div class="fg"><label>MOS / Role (if known)</label><input type="text" name="mos" placeholder="e.g. 11B Infantryman, or leave blank"></div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 16px;">
      <div class="fg"><label>Approximate Arrival in Vietnam</label><input type="text" name="arrived" placeholder="e.g. March 1969, or best guess"></div>
      <div class="fg"><label>Approximate Departure</label><input type="text" name="departed" placeholder="e.g. March 1970, or best guess"></div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 16px;">
      <div class="fg"><label>Hometown (if known)</label><input type="text" name="hometown" placeholder="City, State"></div>
      <div class="fg"><label>Platoon or Assignment (if known)</label><input type="text" name="platoon" placeholder="e.g. Cat Platoon, HQ, Weapons Platoon"></div>
    </div>

    <div class="fg">
      <label>Status</label>
      <select name="status">
        <option value="">Unknown</option>
        <option>Living veteran</option>
        <option>Deceased — natural causes</option>
        <option>KIA — killed in action</option>
      </select>
    </div>

    <div class="fg">
      <label>Names of soldiers he served with (if known)</label>
      <textarea name="fellow_soldiers" placeholder="Even partial names help — they may connect to other profiles in the archive."></textarea>
    </div>

    <div class="fg">
      <label>Anything else about his service you'd like us to know</label>
      <textarea name="service_notes" placeholder="Awards, incidents, anything that stands out from letters or stories."></textarea>
    </div>

    {# ── MATERIALS ── #}
    <div class="contrib-panel-hed" style="margin: 36px 0 8px;">Materials You Have</div>
    <p class="contrib-panel-deck">Check everything that applies. You don't need everything — even one photograph is enough to start.</p>

    <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px;">
      <label style="display: flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; cursor: pointer;"><input type="checkbox" name="has_photos" value="yes" style="width:16px;height:16px;accent-color:var(--y);"> Photographs (in-country, unit, or personal)</label>
      <label style="display: flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; cursor: pointer;"><input type="checkbox" name="has_letters" value="yes" style="width:16px;height:16px;accent-color:var(--y);"> Letters home or other written correspondence</label>
      <label style="display: flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; cursor: pointer;"><input type="checkbox" name="has_dd214" value="yes" style="width:16px;height:16px;accent-color:var(--y);"> DD-214 or separation papers</label>
      <label style="display: flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; cursor: pointer;"><input type="checkbox" name="has_orders" value="yes" style="width:16px;height:16px;accent-color:var(--y);"> Orders, citations, or official documents</label>
      <label style="display: flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; cursor: pointer;"><input type="checkbox" name="has_medals" value="yes" style="width:16px;height:16px;accent-color:var(--y);"> Medals or decorations (can photograph)</label>
      <label style="display: flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; cursor: pointer;"><input type="checkbox" name="has_memoir" value="yes" style="width:16px;height:16px;accent-color:var(--y);"> Memoir, diary, or field notes</label>
      <label style="display: flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; cursor: pointer;"><input type="checkbox" name="has_other" value="yes" style="width:16px;height:16px;accent-color:var(--y);"> Other materials</label>
    </div>

    <div class="fg">
      <label>Describe your materials in more detail (optional)</label>
      <textarea name="materials_detail" placeholder="How many photos? Are letters dated? Any photos with names on the back? Anything particularly significant?"></textarea>
    </div>

    {# ── YOUR INFORMATION ── #}
    <div class="contrib-panel-hed" style="margin: 36px 0 20px;">Your Information</div>

    <div class="fg"><label>Your Name</label><input type="text" name="submitter_name" placeholder="Full name" required></div>

    <div class="fg">
      <label>Your Relationship to the Soldier</label>
      <select name="relationship" required>
        <option value="">Select...</option>
        <option>Son or daughter</option>
        <option>Grandchild</option>
        <option>Spouse or partner</option>
        <option>Sibling</option>
        <option>Other family member</option>
        <option>Fellow veteran — I served with him</option>
        <option>Researcher / Historian</option>
        <option>Other</option>
      </select>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 16px;">
      <div class="fg"><label>Your Email</label><input type="email" name="email" placeholder="We'll follow up here" required></div>
      <div class="fg"><label>Your Phone (optional)</label><input type="tel" name="phone" placeholder="If you prefer a call"></div>
    </div>

    <div class="fg">
      <label>Best way to reach you</label>
      <select name="contact_pref">
        <option value="">No preference</option>
        <option>Email</option>
        <option>Phone call</option>
        <option>Text message</option>
      </select>
    </div>

    <div class="fg">
      <label>Anything else before we follow up?</label>
      <textarea name="additional_notes" placeholder="Questions, concerns, timing — anything helpful."></textarea>
    </div>

    <button class="submit-btn" type="submit">Submit Intake Form</button>
    <div class="priv-note" style="margin-top: 16px;">Your contact information will not be published. Originals will never be requested without your explicit consent. You retain ownership of all submitted materials. There is no cost to have a profile built.</div>

  </form>

</div>
</div>

