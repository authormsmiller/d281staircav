---
layout: base.njk
title: Search Records
permalink: /search/
---

<div class="search-page">

  <div class="search-header">
    <h1 class="search-title">Search Records</h1>
    <p class="search-subtitle">
      Search by name, nickname, platoon, or unit. Firebase and location
      search coming as those records are added to the archive.
    </p>
  </div>

  <form class="search-form" id="search-form" action="/search/" method="get">
    <div class="search-input-row">
      <input
        type="search"
        id="search-input"
        name="q"
        class="search-input"
        placeholder="Name, nickname, platoon…"
        autocomplete="off"
        spellcheck="false"
      />
      <button type="submit" class="search-btn">Search</button>
    </div>
  </form>

  <div id="search-results" class="search-results" aria-live="polite"></div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/lunr.js/2.3.9/lunr.min.js"></script>
<script>
(function () {

  function qs(sel) { return document.querySelector(sel); }

  function getParam(key) {
    return new URLSearchParams(window.location.search).get(key) || "";
  }

  function photoPath(soldier) {
    if (!soldier.profile_photo) return null;
    return "/soldiers/" + soldier.slug + "/photos/profile/" + soldier.profile_photo;
  }

  function platoonShort(platoon) {
    return platoon ? platoon.replace(/\s*\([^)]*\)/, "") : "";
  }

  let lunrIndex = null;
  let records   = {};

  fetch("/search-index.json")
    .then(function (r) { return r.json(); })
    .then(function (data) {

      data.forEach(function (s) { records[s.id] = s; });

      lunrIndex = lunr(function () {
        this.ref("id");
        this.field("name",      { boost: 10 });
        this.field("last_name", { boost: 8  });
        this.field("nickname",  { boost: 8  });
        this.field("platoon",   { boost: 4  });
        this.field("rank",      { boost: 2  });
        this.field("mos",       { boost: 2  });
        this.field("hometown",  { boost: 2  });
        this.field("excerpt",   { boost: 1  });

        data.forEach(function (s) { this.add(s); }, this);
      });

      const q = getParam("q");
      if (q) {
        qs("#search-input").value = q;
        runSearch(q);
      }
    })
    .catch(function (err) {
      console.error("searchIndex load failed:", err);
      qs("#search-results").innerHTML =
        '<p class="search-error">Search index could not be loaded. Try refreshing the page.</p>';
    });

  function runSearch(query) {
    const container = qs("#search-results");
    if (!query.trim()) { container.innerHTML = ""; return; }
    if (!lunrIndex)    { container.innerHTML = '<p class="search-status">Index loading\u2026</p>'; return; }

    let hits;
    try {
      hits = lunrIndex.search(query + "*");
      if (!hits.length) hits = lunrIndex.search(query + "~1");
    } catch (e) {
      hits = [];
    }

    const soldiers = hits.map(function (h) { return records[h.ref]; }).filter(Boolean);
    renderResults(query, soldiers, container);
  }

  function renderResults(query, soldiers, container) {
    if (!soldiers.length) {
      container.innerHTML =
        '<p class="search-no-results">No records found for <strong>' +
        escHtml(query) + '</strong>.</p>';
      return;
    }

    let html = "";

    html += '<section class="result-group">';
    html += '<h2 class="result-group-label">Soldiers <span class="result-count">' + soldiers.length + '</span></h2>';
    html += '<ul class="result-list">';

    soldiers.forEach(function (s) {
      const photo = photoPath(s);
      const platoon = platoonShort(s.platoon);
      const meta = [s.rank, platoon, s.hometown].filter(Boolean).join(" \u00b7 ");

      html += '<li class="result-item">';
      html += '  <a href="/soldiers/' + s.slug + '/" class="result-link">';

      if (photo) {
        html += '  <div class="result-photo">';
        html += '    <img src="' + escHtml(photo) + '" alt="' + escHtml(s.name) + '" loading="lazy" />';
        html += '  </div>';
      } else {
        html += '  <div class="result-photo result-photo--placeholder">';
        html += '    <span>' + initials(s) + '</span>';
        html += '  </div>';
      }

      html += '  <div class="result-body">';
      html += '    <p class="result-name">' + escHtml(s.name) + '</p>';
      if (meta) html += '    <p class="result-meta">' + escHtml(meta) + '</p>';
      if (s.excerpt) html += '    <p class="result-excerpt">' + escHtml(truncate(s.excerpt, 120)) + '</p>';
      html += '  </div>';
      html += '  </a>';
      html += '</li>';
    });

    html += '</ul></section>';

    html += '<section class="result-group result-group--coming-soon">';
    html += '<h2 class="result-group-label">Verbal Accounts <span class="result-coming">coming soon</span></h2>';
    html += '<p class="result-stub-note">Verbal accounts and recorded testimony will appear here as they are added to the archive.</p>';
    html += '</section>';

    html += '<section class="result-group result-group--coming-soon">';
    html += '<h2 class="result-group-label">Locations &amp; Firebases <span class="result-coming">coming soon</span></h2>';
    html += '<p class="result-stub-note">Firebase and location records will appear here once those pages are built.</p>';
    html += '</section>';

    container.innerHTML = html;
  }

  function escHtml(str) {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function truncate(str, len) {
    if (!str || str.length <= len) return str;
    return str.slice(0, len).replace(/\s+\S*$/, "") + "\u2026";
  }

  function initials(s) {
    const f = s.first_name ? s.first_name[0] : "";
    const l = s.last_name  ? s.last_name[0]  : "";
    return (f + l).toUpperCase();
  }

  qs("#search-form").addEventListener("submit", function (e) {
    e.preventDefault();
    const q = qs("#search-input").value.trim();
    if (!q) return;

    const url = new URL(window.location.href);
    url.searchParams.set("q", q);
    history.pushState({}, "", url);

    runSearch(q);
  });

})();
</script>
