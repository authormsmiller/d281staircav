<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ first_name }} {{ last_name }} — {{ site.title }}</title>
<meta name="description" content="Service profile for {{ rank }} {{ first_name }} {{ last_name }}, {{ platoon }}, D Co. 2/8 CAV.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

<header class="masthead">
  <a class="masthead-brand" href="/">
    <svg viewBox="0 0 26 31" fill="none" width="26" height="31">
      <path d="M13 2L2 6.5v12c0 8 5.5 12.5 11 13.5 5.5-1 11-5.5 11-13.5v-12L13 2z" fill="#F5C400" stroke="#C8A800" stroke-width="0.8"/>
      <path d="M2 6.5l22 0l-2.5 20" stroke="#0a0a08" stroke-width="9" fill="none"/>
      <ellipse cx="21" cy="10" rx="5.5" ry="6" fill="#0a0a08"/>
    </svg>
    <div class="brand-lines">
      <div class="brand-unit">D Co. 2/8 CAV</div>
      <div class="brand-sub">Angry Skipper Archive</div>
    </div>
  </a>
  <nav class="masthead-nav">
    <a class="nav-btn" href="/families/">For Families</a>
    <a class="nav-btn" href="/">Overview</a>
    <a class="nav-btn" href="/roster/">Roster</a>
    <a class="nav-btn cta" href="/contribute/">Contribute</a>
  </nav>
</header>

<div class="breadcrumb show">
  <a class="bc-link" href="/">Archive</a>
  <span class="bc-sep">›</span>
  <a class="bc-link" href="/roster/">Roster</a>
  <span class="bc-sep">›</span>
  <span>{{ rank }} {{ first_name }} {{ last_name }}</span>
</div>

<main>

{# ── PROFILE HERO ── #}
<div class="prof-hero">

  {# Photo column #}
  <div class="prof-photo-col">
    <div class="prof-photo-frame">
      {% if profile_photo %}
        <img
          src="/soldiers/{{ slug }}/photos/profile/{{ profile_photo }}"
          alt="{{ first_name }} {{ last_name }}"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        >
      {% endif %}
      <div class="prof-photo-placeholder" {% if profile_photo %}style="display:none"{% endif %}>
        {{ first_name[0] }}{{ last_name[0] }}
      </div>
    </div>
    <div class="prof-photo-cap">Then &amp; Now</div>
  </div>

  {# Info column #}
  <div class="prof-info">

    {% if status == "Deceased" or status == "KIA" %}
      <div class="prof-deceased">
        {% if status == "KIA" %}KIA · Vietnam
        {% else %}Deceased{% if year_deceased %} · {{ year_deceased }}{% endif %}
        {% endif %}
      </div>
    {% endif %}

    <div class="prof-name">{{ first_name }}<br>{{ last_name }}</div>
    <div class="prof-rank">{{ rank }} &nbsp;·&nbsp; {{ mos }}</div>

    {% if nickname %}
      <div class="prof-nickname">Known as <span class="prof-nickname-val">"{{ nickname }}"</span></div>
    {% endif %}

    <div class="prof-grid">
      <div class="pg-item">
        <div class="pg-label">Platoon</div>
        <div class="pg-value">{{ platoon }}</div>
      </div>
      <div class="pg-item">
        <div class="pg-label">In-Country Service</div>
        <div class="pg-value">{{ arrived }} – {{ departed }}</div>
      </div>
      <div class="pg-item">
        <div class="pg-label">Home of Record</div>
        <div class="pg-value">{{ hometown }}</div>
      </div>
      <div class="pg-item">
        <div class="pg-label">Character of Service</div>
        <div class="pg-value">{{ character_of_service | default("Honorable") }}</div>
      </div>
    </div>

    {% if decorations and decorations.length %}
      <div class="prof-medals-label">Decorations &amp; Awards</div>
      <div class="prof-medals">
        {% for medal in decorations %}
          <span class="pmed {% if medal.distinguished %}{% else %}dim{% endif %}">{{ medal }}</span>
        {% endfor %}
      </div>
    {% endif %}

    <div class="prof-actions">
      <a class="prof-btn prof-btn-primary" href="/contribute/">Share a Memory</a>
      {% if family_contact %}
        <a class="prof-btn prof-btn-ghost" href="mailto:{{ site.contact_email }}?subject=Re: {{ first_name }} {{ last_name }}">Contact Family</a>
      {% endif %}
    </div>

  </div>
</div>

{# ── SERVICE TIMELINE ── #}
{% if timeline and timeline.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Service Timeline</div>
    <div class="section-rule"></div>
    <div class="section-meta">{{ arrived }} – {{ departed }}</div>
  </div>

  {% if timeline_source %}
    <p class="timeline-intro">{{ timeline_source }}</p>
  {% endif %}

  <div class="tl">
    {% for entry in timeline %}
      <div class="tl-entry">
        <div class="tl-dot {{ entry.type | default('move') }}"></div>
        <div class="tl-date">{{ entry.date }}</div>
        {% if entry.tags %}
          {% for tag in entry.tags %}
            <span class="tl-tag tl-tag-{{ tag.type }}">{{ tag.label }}</span>
          {% endfor %}
        {% endif %}
        <div class="tl-hed">{{ entry.headline }}</div>
        <div class="tl-body">{{ entry.body }}</div>
        {% if entry.source_notice %}
          <div class="source-notice">
            <div class="sn-head">⚠ Source Notice — Multiple Accounts Exist</div>
            <div class="sn-body">{{ entry.source_notice }}</div>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── PHOTO GALLERY ── #}
{% if photos and photos.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Photographs</div>
    <div class="section-rule"></div>
    <div class="section-meta">{{ photos.length }} Images</div>
  </div>

  {% if photo_intro %}
    <p class="timeline-intro" style="font-style:italic;">{{ photo_intro }}</p>
  {% endif %}

  {# Build one flat JS array of all photos for the slideshow #}
  <script>
    var PHOTO_SLIDES = [
      {% for photo in photos %}
      {
        src: "/soldiers/{{ slug }}/photos/{{ photo.subfolder }}/{{ photo.filename }}",
        caption: {{ (photo.caption or photo.caption_short or photo.filename) | dump | safe }},
        credit: {{ (photo.credit or "") | dump | safe }},
        date: {{ (photo.date_approx or "") | dump | safe }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ];
  </script>

  {# Iterate photos twice — once for "his", once for "of him" #}
  <div class="gallery-sublabel">Through His Eyes — Photographs He Took</div>
  <div class="photo-grid">
    {% for photo in photos %}
      {% if photo.photographer != "unknown-of" and photo.photographer != "known-of" %}
        <div class="photo-card {{ 'wide' if photo.wide }}"
             onclick="lbOpen({{ loop.index0 }}, PHOTO_SLIDES)">
          <img src="/soldiers/{{ slug }}/photos/{{ photo.subfolder }}/{{ photo.filename }}" alt="{{ photo.caption_short if photo.caption_short else photo.filename }}" loading="lazy">
          <div class="photo-overlay">
            <div class="photo-cap-text">{{ photo.caption_short if photo.caption_short else photo.filename }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="gallery-sublabel">Among His Brothers — Photographs Others Took of {{ first_name }}</div>
  <div class="photo-grid">
    {% for photo in photos %}
      {% if photo.photographer == "unknown-of" or photo.photographer == "known-of" %}
        <div class="photo-card {{ 'wide' if photo.wide }}"
             onclick="lbOpen({{ loop.index0 }}, PHOTO_SLIDES)">
          <img src="/soldiers/{{ slug }}/photos/{{ photo.subfolder }}/{{ photo.filename }}" alt="{{ photo.caption_short if photo.caption_short else photo.filename }}" loading="lazy">
          <div class="photo-overlay">
            <div class="photo-cap-text">{{ photo.caption_short if photo.caption_short else photo.filename }}</div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if wartime_content_notice %}
    <div class="content-notice">
      <div>
        <strong>Note on Wartime Content</strong>
        <p>This gallery includes photographs taken in a combat zone. Some images depict the realities of war. They are preserved here as historical documentation.</p>
      </div>
    </div>
  {% endif %}
</div>
{% endif %}

{# ── ALSO APPEARS IN ── #}
{% set crossPhotos = [] %}
{% for photo in collections.allPhotos %}
  {% if photo.contains and slug in photo.contains and photo.source_soldier_slug != slug %}
    {% set crossPhotos = crossPhotos.concat([photo]) %}
  {% endif %}
{% endfor %}
{% if crossPhotos.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Also Appears In</div>
    <div class="section-rule"></div>
    <div class="section-meta">{{ crossPhotos.length }} Images</div>
  </div>
  <div class="photo-grid">
    {% for photo in crossPhotos %}
      <div class="photo-card {{ 'wide' if photo.wide }}"
           onclick="lb('/soldiers/{{ photo.source_soldier_slug }}/photos/{{ photo.subfolder }}/{{ photo.filename }}','{{ photo.caption_short if photo.caption_short else photo.filename }}','{{ photo.credit }}')">
        <img src="/soldiers/{{ photo.source_soldier_slug }}/photos/{{ photo.subfolder }}/{{ photo.filename }}"
             alt="{{ photo.caption_short if photo.caption_short else photo.filename }}" loading="lazy">
        <div class="photo-overlay">
          <div class="photo-cap-text">{{ photo.caption_short if photo.caption_short else photo.filename }}</div>
          <div class="photo-cap-credit">From the {{ photo.source_soldier_name }} collection</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── DOCUMENTS ── #}
{% if documents and documents.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Documents &amp; Records</div>
    <div class="section-rule"></div>
  </div>
  <div class="doc-list">
    {% for doc in documents %}
      <div class="doc-item">
        <div class="doc-icon">{{ doc.icon | default("📄") }}</div>
        <div style="flex:1;">
          <div class="doc-title">{{ doc.title }}</div>
          <div class="doc-meta">{{ doc.meta }}</div>
          {% if doc.note %}
            <div style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--dim);margin-top:5px;">{{ doc.note }}</div>
          {% endif %}
        </div>
        <div class="doc-type">{{ doc.type }}</div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── SERVED ALONGSIDE ── #}
{% if brothers and brothers.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Served Alongside</div>
    <div class="section-rule"></div>
    <div class="section-meta">{{ platoon }}</div>
  </div>
  <div class="bros-grid">
    {% for bro in brothers %}
      <div class="bro-card">
        <div class="bro-circle {% if bro.kia %}kia{% endif %}">
          <span class="bro-init {{ 'kia' if bro.kia }}">{{ bro.name[0] }}</span>
        </div>
        <div class="bro-name">{{ bro.name }}</div>
        <div class="bro-detail">{{ bro.platoon }} · {{ bro.dates }}</div>
        {% if bro.status %}
          <div class="bro-detail {% if bro.kia %}kia{% endif %}">{{ bro.status }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  <div style="margin-top:20px;">
    <a class="tl-link" href="/roster/">View full roster →</a>
  </div>
</div>
{% endif %}

{# ── PROFILE CTA ── #}
<div class="prof-cta">
  <div>
    <h3>Did You Know {{ first_name }}, or Serve Alongside {{ first_name }}?</h3>
    <p>We are actively collecting photographs, letters, and memories for this profile. Submissions are reviewed before publication. If you served with {{ first_name }} — or are a family member with materials — we'd be grateful to hear from you.</p>
  </div>
  <div class="prof-cta-btns">
    <a class="land-cta" href="/contribute/">Submit Materials</a>
  </div>
</div>

<footer>
  <div class="footer-left">D Co. 2/8 CAV · Angry Skipper</div>
  <div class="footer-right">1st Cavalry Division (Airmobile) · Vietnam 1965–1972<br>Archive initiated April 2026 · Compiled by family</div>
</footer>

</main>

<div class="toast" id="toastEl"></div>
<div class="lightbox" id="lightbox" onclick="lbClose(event)">
  <div class="lb-inner">
    <button class="lb-close" onclick="lbClose()">✕ CLOSE</button>
    <img id="lb-img" src="" alt="">
    <div class="lb-cap">
      <div class="lb-cap-meta">
        <span id="lb-cap-date"></span>
        <span id="lb-counter"></span>
      </div>
      <p id="lb-cap-p"></p>
      <small id="lb-cap-s"></small>
    </div>
    <div class="lb-nav">
      <button id="lb-prev" class="lb-arrow" onclick="event.stopPropagation();lbPrev()">← PREV</button>
      <button id="lb-next" class="lb-arrow" onclick="event.stopPropagation();lbNext()">NEXT →</button>
    </div>
  </div>
</div>
<script src="/assets/js/main.js"></script>
</body>
</html>
