<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ first_name }} {{ last_name }} — {{ site.title }}</title>
<meta name="description" content="Service profile for {{ rank }} {{ first_name }} {{ last_name }}, {{ platoon }}, D Co. 2/8 CAV.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

{% include "partials/masthead.njk" %}

<div class="breadcrumb show">
  <a class="bc-link" href="/">Archive</a>
  <span class="bc-sep">›</span>
  <a class="bc-link" href="/roster/">Roster</a>
  <span class="bc-sep">›</span>
  <span>{{ rank }} {{ first_name }} {{ last_name }}</span>
</div>

<main>

{# ── PROFILE HERO ── #}
<div class="prof-hero">

  {# Photo column #}
  <div class="prof-photo-col">
    <div class="prof-photo-frame">
      {% if profile_photo %}
        <img
          src="/soldiers/{{ slug }}/photos/profile/{{ profile_photo }}"
          alt="{{ first_name }} {{ last_name }}"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        >
      {% endif %}
      <div class="prof-photo-placeholder" {% if profile_photo %}style="display:none"{% endif %}>
        {{ first_name[0] }}{{ last_name[0] }}
      </div>
    </div>
    <div class="prof-photo-cap">Then &amp; Now</div>
  </div>

  {# Info column #}
  <div class="prof-info">

    {% if status == "Deceased" or status == "KIA" %}
      <div class="prof-deceased">
        {% if status == "KIA" %}KIA · Vietnam
        {% else %}Deceased{% if year_deceased %} · {{ year_deceased }}{% endif %}
        {% endif %}
      </div>
    {% endif %}

    <div class="prof-name">{{ first_name }}<br>{{ last_name }}</div>
    <div class="prof-rank">{{ rank }} &nbsp;·&nbsp; {{ platoon }} &nbsp;·&nbsp; {{ mos }}</div>

    {% if nickname %}
      <div class="prof-nickname">Known as <span class="prof-nickname-val">"{{ nickname }}"</span></div>
    {% endif %}

    <div class="prof-grid">
      <div class="pg-item">
        <div class="pg-label">In-Country Service</div>
        <div class="pg-value">{{ arrived }} – {{ departed }}</div>
      </div>
      <div class="pg-item">
        <div class="pg-label">Home of Record</div>
        <div class="pg-value">{{ hometown }}</div>
      </div>
      <div class="pg-item">
        <div class="pg-label">Character of Service</div>
        <div class="pg-value">{{ character_of_service | default("Honorable") }}</div>
      </div>
      <div class="pg-item">
        <div class="pg-label">Archive Status</div>
        <div class="pg-value">{{ archive_status | default("Active") }}</div>
      </div>
    </div>

    <div class="prof-actions">
      <a class="prof-btn prof-btn-primary" href="/contribute/">Share a Memory</a>
      {% if family_contact %}
        <a class="prof-btn prof-btn-ghost" href="mailto:{{ site.contact_email }}?subject=Re: {{ first_name }} {{ last_name }}">Contact Family</a>
      {% endif %}
    </div>

  </div>
</div>

{# ── TAB BAR ── #}
<div class="tabs-bar">
  <div class="tab active" data-tab="timeline">Timeline</div>
  <div class="tab" data-tab="photos">Photos</div>
  <div class="tab" data-tab="alongside">Served alongside</div>
  <div class="tab" data-tab="accounts">Verbal accounts</div>
  <div class="tab" data-tab="documents">Documents</div>
  <div class="tab" data-tab="letters">Letters</div>
  <div class="tab" data-tab="service">Service record</div>
  <div class="tab" data-tab="external">External resources</div>
</div>

{# ── TAB: TIMELINE ── #}
<div class="tab-content" id="tab-timeline">
  {% if timeline and timeline.length %}
    {% if timeline_source %}
      <p class="timeline-intro">{{ timeline_source }}</p>
    {% endif %}
    <div class="tl">
      {% for entry in timeline %}
        <div class="tl-entry">
          <div class="tl-dot {{ entry.type | default('move') }}"></div>
          <div class="tl-date">{{ entry.date }}</div>
          {% if entry.tags %}
            {% for tag in entry.tags %}
              <span class="tl-tag tl-tag-{{ tag.type }}">{{ tag.label }}</span>
            {% endfor %}
          {% endif %}
          <div class="tl-hed">{{ entry.headline }}</div>
          <div class="tl-body">{{ entry.body }}</div>
          {% if entry.source_notice %}
            <div class="source-notice">
              <div class="sn-head">⚠ Source Notice — Multiple Accounts Exist</div>
              <div class="sn-body">{{ entry.source_notice }}</div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="tab-empty">
      No timeline on record yet.<br>
      <a href="/contribute/">Know something about {{ first_name }}'s service? Tell us →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: PHOTOS ── #}
<div class="tab-content" id="tab-photos" style="display:none">

  {#
    Pull from crawler output first.
    photosBySlug is keyed by soldier slug; each entry has subfolders as keys.
    Flatten all subfolders into a single allPhotos array for the PHOTO_SLIDES
    script and the gallery loops — same shape the old `photos` array had,
    with `soldier_slug` added so cross-soldier lookups work.
  #}
  {% set crawlerEntry = photosBySlug[slug] %}
  {% set allPhotos = [] %}
  {% if crawlerEntry %}
    {% if crawlerEntry.profile %}
      {% for p in crawlerEntry.profile %}{% set allPhotos = (allPhotos.push(p), allPhotos) %}{% endfor %}
    {% endif %}
    {% if crawlerEntry.field %}
      {% for p in crawlerEntry.field %}{% set allPhotos = (allPhotos.push(p), allPhotos) %}{% endfor %}
    {% endif %}
    {% if crawlerEntry["field/events"] %}
      {% for p in crawlerEntry["field/events"] %}{% set allPhotos = (allPhotos.push(p), allPhotos) %}{% endfor %}
    {% endif %}
  {% else %}
    {# Fallback: no index.md files yet — use old front matter photos array #}
    {% set allPhotos = photos %}
  {% endif %}

  {% if allPhotos and allPhotos.length %}

    {% if photo_intro %}
      <p class="timeline-intro" style="font-style:italic;">{{ photo_intro }}</p>
    {% endif %}

    {#
      PHOTO_SLIDES — build from allPhotos.
      url field comes from crawler; fall back to constructed path for legacy entries.
    #}
    <script>
      var PHOTO_SLIDES = [
        {% for photo in allPhotos %}
        {
          src: {{ (photo.url if photo.url else ("/media/photos/soldiers/" + slug + "/" + photo.subfolder + "/" + photo.filename)) | dump | safe }},
          caption: {{ (photo.caption or photo.caption_short or photo.filename) | dump | safe }},
          credit: {{ (photo.credit or "") | dump | safe }},
          date: {{ (photo.date or photo.date_approx or "") | dump | safe }}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ];
    </script>

    {# ── Gallery 1: Photos he took ── #}
    {% set tookPhotos = [] %}
    {% for photo in allPhotos %}
      {% if photo.photographer != "unknown-of" and photo.photographer != "known-of" %}
        {% set tookPhotos = (tookPhotos.push(photo), tookPhotos) %}
      {% endif %}
    {% endfor %}

    {% if tookPhotos.length %}
      <div class="gallery-sublabel">Through His Eyes — Photographs He Took</div>
      <div class="photo-grid">
        {% for photo in tookPhotos %}
          {% set photoSrc = photo.url if photo.url else ("/media/photos/soldiers/" + slug + "/" + photo.subfolder + "/" + photo.filename) %}
          <div class="photo-card {{ 'wide' if photo.wide }}"
               onclick="lbOpen({{ loop.index0 }}, PHOTO_SLIDES)">
            <img src="{{ photoSrc }}"
                 alt="{{ photo.caption_short if photo.caption_short else photo.filename }}"
                 loading="lazy">
            <div class="photo-overlay">
              <div class="photo-cap-text">{{ photo.caption_short if photo.caption_short else photo.filename }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# ── Gallery 2: Photos others took of him ── #}
    {% set ofPhotos = [] %}
    {% for photo in allPhotos %}
      {% if photo.photographer == "unknown-of" or photo.photographer == "known-of" %}
        {% set ofPhotos = (ofPhotos.push(photo), ofPhotos) %}
      {% endif %}
    {% endfor %}

    {% if ofPhotos.length %}
      <div class="gallery-sublabel">Among His Brothers — Photographs Others Took of {{ first_name }}</div>
      <div class="photo-grid">
        {% for photo in ofPhotos %}
          {% set photoSrc = photo.url if photo.url else ("/media/photos/soldiers/" + slug + "/" + photo.subfolder + "/" + photo.filename) %}
          <div class="photo-card {{ 'wide' if photo.wide }}"
               onclick="lbOpen({{ loop.index0 }}, PHOTO_SLIDES)">
            <img src="{{ photoSrc }}"
                 alt="{{ photo.caption_short if photo.caption_short else photo.filename }}"
                 loading="lazy">
            <div class="photo-overlay">
              <div class="photo-cap-text">{{ photo.caption_short if photo.caption_short else photo.filename }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# ── Gallery 3: Cross-soldier photos (this soldier appears in another's collection) ── #}
    {#
      Sourced from photosBySlug._byContains[slug], which the crawler populates
      at build time from all soldiers' index.md files.
      _byContains is non-enumerable so it won't appear in template iteration,
      but direct property access works fine.
    #}
    {% set crossPhotos = photosBySlug._byContains[slug] if photosBySlug._byContains else [] %}
    {% set filteredCrossPhotos = [] %}
    {% if crossPhotos %}
      {% for photo in crossPhotos %}
        {% if photo.soldier_slug != slug %}
          {% set filteredCrossPhotos = (filteredCrossPhotos.push(photo), filteredCrossPhotos) %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if filteredCrossPhotos.length %}
      <div class="gallery-sublabel">Photographs by Fellow Soldiers</div>
      <div class="photo-grid">
        {% for photo in filteredCrossPhotos %}
          <div class="photo-card {{ 'wide' if photo.wide }}"
               onclick="lb('{{ photo.url }}','{{ photo.caption_short if photo.caption_short else photo.filename }}','{{ photo.credit }}')">
            <img src="{{ photo.url }}"
                 alt="{{ photo.caption_short if photo.caption_short else photo.filename }}"
                 loading="lazy">
            <div class="photo-overlay">
              <div class="photo-cap-text">{{ photo.caption_short if photo.caption_short else photo.filename }}</div>
              <div class="photo-cap-credit">From the {{ photo.soldier_slug | replace("-", " ") | title }} collection</div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if wartime_content_notice %}
      <div class="content-notice">
        <div>
          <strong>Note on Wartime Content</strong>
          <p>This gallery includes photographs taken in a combat zone. Some images depict the realities of war. They are preserved here as historical documentation.</p>
        </div>
      </div>
    {% endif %}

  {% else %}
    <div class="tab-empty">
      No photographs on record yet.<br>
      <a href="/contribute/">Have a photo to contribute? →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: SERVED ALONGSIDE ── #}
<div class="tab-content" id="tab-alongside" style="display:none">
  {% set relatedSoldiers = [] %}
  {% for rel in relationships %}
    {% if slug in rel.soldiers %}
      {% set otherSlug = "" %}
      {% for s in rel.soldiers %}
        {% if s != slug %}{% set otherSlug = s %}{% endif %}
      {% endfor %}
      {% if otherSlug %}
        {% set relatedSoldiers = relatedSoldiers.concat([{ slug: otherSlug, basis: rel.basis, notes: rel.notes }]) %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {% if relatedSoldiers.length %}
    <div class="alongside-grid">
      {% for rel in relatedSoldiers %}
        {% set otherProfile = null %}
        {% for page in collections.all %}
          {% if page.data.slug == rel.slug %}
            {% set otherProfile = page.data %}
          {% endif %}
        {% endfor %}
        <div class="alongside-card">
          <a href="/soldiers/{{ rel.slug }}/" style="text-decoration:none;">
            <div class="alongside-photo">
              {% if otherProfile and otherProfile.profile_photo %}
                <img src="/media/photos/soldiers/{{ rel.slug }}/profile/{{ otherProfile.profile_photo }}"
                     alt="{{ rel.slug }}"
                     style="width:100%;height:100%;object-fit:cover;"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <span style="display:none">{{ rel.slug | upper | truncate(2, true, "") }}</span>
              {% else %}
                {% if otherProfile %}{{ otherProfile.first_name[0] }}{{ otherProfile.last_name[0] }}
                {% else %}?{% endif %}
              {% endif %}
            </div>
          </a>
          <div class="alongside-name">
            <a href="/soldiers/{{ rel.slug }}/" style="color:inherit;text-decoration:none;">
              {% if otherProfile %}{{ otherProfile.first_name }} {{ otherProfile.last_name }}
              {% else %}{{ rel.slug }}{% endif %}
            </a>
          </div>
          {% if otherProfile %}
            <div class="alongside-meta">{{ otherProfile.platoon }}{% if otherProfile.arrived %} · {{ otherProfile.arrived }}–{{ otherProfile.departed }}{% endif %}</div>
          {% endif %}
          <div class="alongside-meta" style="font-style:italic;">{{ rel.basis | replace("-", " ") }}</div>
        </div>
      {% endfor %}

      {# Know someone prompt card #}
      <div class="alongside-card">
        <a href="/contribute/" style="text-decoration:none;">
          <div class="alongside-photo" style="background:transparent;border-style:dashed;font-size:20px;color:var(--dim);">+</div>
        </a>
        <div class="alongside-name" style="color:var(--dim);">
          <a href="/contribute/" style="color:var(--dim);text-decoration:none;">Know someone?</a>
        </div>
        <div class="alongside-meta">Tell us →</div>
      </div>
    </div>
  {% else %}
    <div class="tab-empty">
      No confirmed connections on record yet.<br>
      <a href="/contribute/">Know someone who served alongside {{ first_name }}? Tell us →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: VERBAL ACCOUNTS ── #}
<div class="tab-content" id="tab-accounts" style="display:none">

  {# ── Archive-assembled anecdotes (collections.anecdotes) ── #}
  {% set soldierAnecdotes = [] %}
  {% for anecdote in collections.anecdotes %}
    {% if anecdote.data.soldiers and slug in anecdote.data.soldiers %}
      {% set soldierAnecdotes = soldierAnecdotes.concat([anecdote]) %}
    {% endif %}
  {% endfor %}

  {# ── First-person verbal documents (documentsBySlug crawler) ── #}
  {% set verbalDocs = [] %}
  {% set soldierDocs = documentsBySlug[slug] %}
  {% if soldierDocs %}
    {% for doc in soldierDocs.authored %}
      {% if doc.type == "verbal" %}
        {% set verbalDocs = verbalDocs.concat([doc]) %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% if soldierAnecdotes.length or verbalDocs.length %}

    {% if verbalDocs.length %}
      <div class="section-header">
        <div class="section-title" style="font-size:13px;">In {{ first_name }}'s Own Words</div>
        <div class="section-rule"></div>
        <div class="section-meta">{{ verbalDocs.length }} Account{% if verbalDocs.length != 1 %}s{% endif %}</div>
      </div>
      <div class="doc-list">
        {% for doc in verbalDocs %}
          <div class="doc-item">
            <div class="doc-icon">✍️</div>
            <div style="flex:1;">
              <a class="doc-title doc-link" href="/documents/{{ doc.path }}/">{{ doc.title if doc.title else doc.slug }}</a>
              <div class="doc-meta">
                {% if doc.doc_date %}{{ doc.doc_date }}{% endif %}
                {% if not doc.date_known %}<span class="doc-badge doc-badge-pending">Date unknown</span>{% endif %}
              </div>
              {% if doc.source %}<div class="doc-meta">{{ doc.source }}</div>{% endif %}
            </div>
            <div class="doc-type">Verbal</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if soldierAnecdotes.length %}
      <div class="section-header" {% if verbalDocs.length %}style="margin-top:24px;"{% endif %}>
        <div class="section-title" style="font-size:13px;">Archive Accounts</div>
        <div class="section-rule"></div>
        <div class="section-meta">{{ soldierAnecdotes.length }} Account{% if soldierAnecdotes.length != 1 %}s{% endif %}</div>
      </div>
      <div class="doc-list">
        {% for anecdote in soldierAnecdotes %}
          <div class="doc-item">
            <div class="doc-icon">💬</div>
            <div style="flex:1;">
              <a class="doc-title doc-link" href="{{ anecdote.data.permalink }}">{{ anecdote.data.title }}</a>
              <div class="doc-meta">{{ anecdote.data.date_approx }} · {{ anecdote.data.source_short }}</div>
              {% if anecdote.data.summary %}
                <div class="doc-meta" style="margin-top:0.25rem;">{{ anecdote.data.summary }}</div>
              {% endif %}
            </div>
            <div class="doc-type">{{ anecdote.data.type }}</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

  {% else %}
    <div class="tab-empty">
      No verbal accounts on record.<br>
      <a href="/contribute/">Share a memory →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: DOCUMENTS ── #}
<div class="tab-content" id="tab-documents" style="display:none">
  {% set soldierDocs = documentsBySlug[slug] %}

  {% if soldierDocs %}

    {# ── Authored by ── #}
    {% set authored = [] %}
    {% for doc in soldierDocs.authored %}
      {% if doc.type != "letter" and doc.type != "verbal" %}
        {% set authored = authored.concat([doc]) %}
      {% endif %}
    {% endfor %}
    {% if authored.length %}
      <div class="section-header">
        <div class="section-title" style="font-size:13px;">Authored by {{ first_name }}</div>
        <div class="section-rule"></div>
        <div class="section-meta">{{ authored.length }} Record{% if authored.length != 1 %}s{% endif %}</div>
      </div>
      <div class="doc-list">
        {% for doc in authored %}
          <div class="doc-item">
            <div class="doc-icon">📄</div>
            <div style="flex:1;">
              <a class="doc-title doc-link" href="/documents/{{ doc.path }}/">{{ doc.title if doc.title else doc.slug }}</a>
              <div class="doc-meta">
                {{ doc.type }}
                {% if doc.doc_date %} · {{ doc.doc_date }}{% endif %}
                {% if not doc.date_known %}<span class="doc-badge doc-badge-pending">Date unknown</span>{% endif %}
              </div>
              {% if doc.source %}<div class="doc-meta">{{ doc.source }}</div>{% endif %}
            </div>
            <div class="doc-type">{{ doc.type }}</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# ── Explicitly referenced ── #}
    {% set referenced = soldierDocs.referenced %}
    {% if referenced.length %}
      <div class="section-header" style="margin-top:24px;">
        <div class="section-title" style="font-size:13px;">Explicitly Referenced</div>
        <div class="section-rule"></div>
        <div class="section-meta">{{ referenced.length }} Record{% if referenced.length != 1 %}s{% endif %}</div>
      </div>
      <div class="doc-list">
        {% for doc in referenced %}
          <div class="doc-item">
            <div class="doc-icon">📄</div>
            <div style="flex:1;">
              <a class="doc-title doc-link" href="/documents/{{ doc.path }}/">{{ doc.title if doc.title else doc.slug }}</a>
              <div class="doc-meta">
                {{ doc.type }}
                {% if doc.doc_date %} · {{ doc.doc_date }}{% endif %}
                {% if not doc.date_known %}<span class="doc-badge doc-badge-pending">Date unknown</span>{% endif %}
              </div>
              {% if doc.source %}<div class="doc-meta">{{ doc.source }}</div>{% endif %}
            </div>
            <div class="doc-type">{{ doc.type }}</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# ── Tagged ── #}
    {% set tagged = soldierDocs.tagged %}
    {% if tagged.length %}
      <div class="section-header" style="margin-top:24px;">
        <div class="section-title" style="font-size:13px;">Also Present</div>
        <div class="section-rule"></div>
        <div class="section-meta">{{ tagged.length }} Record{% if tagged.length != 1 %}s{% endif %}</div>
      </div>
      <div class="doc-list">
        {% for doc in tagged %}
          <div class="doc-item">
            <div class="doc-icon">📄</div>
            <div style="flex:1;">
              <a class="doc-title doc-link" href="/documents/{{ doc.path }}/">{{ doc.title if doc.title else doc.slug }}</a>
              <div class="doc-meta">
                {{ doc.type }}
                {% if doc.doc_date %} · {{ doc.doc_date }}{% endif %}
                {% if not doc.date_known %}<span class="doc-badge doc-badge-pending">Date unknown</span>{% endif %}
              </div>
              {% if doc.source %}<div class="doc-meta">{{ doc.source }}</div>{% endif %}
            </div>
            <div class="doc-type doc-type-tagged">Also present</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# ── Nothing found ── #}
    {% if not authored.length and not referenced.length and not tagged.length %}
      <div class="tab-empty">
        No documents on record.<br>
        <a href="/contribute/">Have something to contribute? →</a>
      </div>
    {% endif %}

  {% else %}
    <div class="tab-empty">
      No documents on record.<br>
      <a href="/contribute/">Have something to contribute? →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: LETTERS ── #}
<div class="tab-content" id="tab-letters" style="display:none">
  {% set soldierDocs = documentsBySlug[slug] %}
  {% set letters = [] %}

  {% if soldierDocs %}
    {% for doc in soldierDocs.authored %}
      {% if doc.type == "letter" %}
        {% set letters = letters.concat([doc]) %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% if letters.length %}
    <div class="doc-list">
      {% for doc in letters %}
        <div class="doc-item">
          <div class="doc-icon">✉️</div>
          <div style="flex:1;">
            <a class="doc-title doc-link" href="/documents/{{ doc.path }}/">{{ doc.title if doc.title else doc.slug }}</a>
            <div class="doc-meta">
              {% if doc.doc_date %}{{ doc.doc_date }}{% endif %}
              {% if not doc.date_known %}<span class="doc-badge doc-badge-pending">Date unknown</span>{% endif %}
            </div>
            {% if doc.source %}<div class="doc-meta">{{ doc.source }}</div>{% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="tab-empty">
      No letters on record.<br>
      <a href="/contribute/">Have a letter to contribute? →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: SERVICE RECORD ── #}
<div class="tab-content" id="tab-service" style="display:none">

  <div class="prof-grid" style="margin-bottom:24px;">
    <div class="pg-item">
      <div class="pg-label">MOS</div>
      <div class="pg-value">{{ mos }}</div>
    </div>
    <div class="pg-item">
      <div class="pg-label">Component</div>
      <div class="pg-value">{{ component | default("U.S. Army") }}</div>
    </div>
    <div class="pg-item">
      <div class="pg-label">Unit</div>
      <div class="pg-value">D Co. 2/8 CAV, 1st Air Cavalry Division</div>
    </div>
    <div class="pg-item">
      <div class="pg-label">Character of Service</div>
      <div class="pg-value">{{ character_of_service | default("Honorable") }}</div>
    </div>
  </div>

  {% if decorations and decorations.length %}
    <div class="section-header">
      <div class="section-title" style="font-size:13px;">Decorations &amp; Awards</div>
      <div class="section-rule"></div>
    </div>
    <div class="awards-list">
      {% for medal in decorations %}
        <div class="award-row">
          <span class="award-name {% if medal.distinguished %}{% else %}dim{% endif %}">{{ medal }}</span>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="tab-empty" style="padding-top:16px;">
      No decoration records on file.<br>
      <a href="/contribute/">Know of awards earned? Tell us →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: EXTERNAL RESOURCES ── #}
<div class="tab-content" id="tab-external" style="display:none">
  <div class="tab-empty">
    No external resources on record.<br>
    <a href="/contribute/">Know of something that should be here? →</a>
  </div>
</div>

{# ── PROFILE CTA ── #}
<div class="prof-cta">
  <div>
    <h3>Did You Know {{ first_name }}, or Serve Alongside {{ first_name }}?</h3>
    <p>We are actively collecting photographs, letters, and memories for this profile. Submissions are reviewed before publication. If you served with {{ first_name }} — or are a family member with materials — we'd be grateful to hear from you.</p>
  </div>
  <div class="prof-cta-btns">
    <a class="land-cta" href="/contribute/">Submit Materials</a>
  </div>
</div>

{% include "partials/footer.njk" %}

</main>

<div class="toast" id="toastEl"></div>
<div class="lightbox" id="lightbox" onclick="lbClose(event)">
  <div class="lb-inner">
    <button class="lb-close" onclick="lbClose()">✕ CLOSE</button>
    <img id="lb-img" src="" alt="">
    <div class="lb-cap">
      <div class="lb-cap-meta">
        <span id="lb-cap-date"></span>
        <span id="lb-counter"></span>
      </div>
      <p id="lb-cap-p"></p>
      <small id="lb-cap-s"></small>
    </div>
    <div class="lb-nav">
      <button id="lb-prev" class="lb-arrow" onclick="event.stopPropagation();lbPrev()">← PREV</button>
      <button id="lb-next" class="lb-arrow" onclick="event.stopPropagation();lbNext()">NEXT →</button>
    </div>
  </div>
</div>

<script src="/assets/js/main.js"></script>

<script>
document.querySelectorAll('.tab').forEach(function(tab) {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.tab-content').forEach(function(c) { c.style.display = 'none'; });
    tab.classList.add('active');
    var target = document.getElementById('tab-' + tab.dataset.tab);
    if (target) target.style.display = 'block';
  });
});
</script>

</body>
</html>
