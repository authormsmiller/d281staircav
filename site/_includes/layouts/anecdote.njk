<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — D Co. 2/8 CAV Archive</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

{% include "partials/masthead.njk" %}

<div class="breadcrumb show">
  <a class="bc-link" href="/">Archive</a>
  <span class="bc-sep">›</span>
  <a class="bc-link" href="/soldiers/miller-marvin-dale/">Marvin Dale Miller</a>
  <span class="bc-sep">›</span>
  <span>{{ title }}</span>
</div>

<main>

{# ── ANECDOTE HEADER ── #}
<div class="section" style="padding-bottom:0;">
  <div class="doc-page-flag">Anecdote</div>
  <h1 class="doc-page-title">{{ title }}</h1>
  <div class="doc-page-meta">
    {% if date_approx %}{{ date_approx }}{% endif %}
    {% if source_short %} · {{ source_short }}{% endif %}
  </div>
  {% if soldiers and soldiers.length %}
    <div class="doc-page-tags">
      <span class="doc-page-tags-label">Soldiers mentioned:</span>
      {% for s in soldiers %}
        <a class="doc-page-tag" href="/soldiers/{{ s }}/">{{ s | replace("-", " ") | title }}</a>
      {% endfor %}
    </div>
  {% endif %}
</div>

{# ── NARRATIVE ── #}
<div class="section">
  <div class="section-header">
    <div class="section-title">Account</div>
    <div class="section-rule"></div>
  </div>
  <div class="doc-transcription">
    {{ content | safe }}
  </div>
</div>

{# ── ARCHIVIST NOTES ── #}
{% if archivist_notes %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Archivist Notes</div>
    <div class="section-rule"></div>
  </div>
  <div class="doc-archivist-notes">
    {{ archivist_notes | nl2br | safe }}
  </div>
</div>
{% endif %}

{# ── CTA ── #}
<div class="prof-cta">
  <div>
    <h3>Do You Have Information About This Incident?</h3>
    <p>If you served with D Co. 2/8 CAV and remember this or have additional context, we would be grateful to hear from you.</p>
  </div>
  <div class="prof-cta-btns">
    <a class="land-cta" href="/contribute/">Submit Information</a>
  </div>
</div>

{% include "partials/footer.njk" %}

</main>

<script src="/assets/js/main.js"></sc