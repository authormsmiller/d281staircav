<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — {{ site.title }}</title>
<meta name="description" content="Archive document: {{ title }}{% if author %}, authored by {{ author }}{% endif %}{% if doc_date %}, {{ doc_date }}{% endif %}.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

{% include "partials/masthead.njk" %}

<div class="breadcrumb show">
  <a class="bc-link" href="/">Archive</a>
  <span class="bc-sep">›</span>
  <span>{{ title }}</span>
</div>

<main>

{# ── DOCUMENT HERO ── #}
<div class="doc-hero">
  <div class="doc-hero-meta">
    <span class="doc-type-pill">{{ type | capitalize }}</span>
    {% if doc_date %}<span class="doc-hero-date">{{ doc_date }}</span>{% endif %}
  </div>
  <h1 class="doc-hero-title">{{ title }}</h1>
  {% if author %}
    <div class="doc-hero-byline">
      {% for s in collections.soldiers %}
        {% if s.data.slug == author %}
          By <a href="/soldiers/{{ author }}/" class="doc-hero-link">{{ s.data.first_name }} {{ s.data.last_name }}</a>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="doc-hero-actions">
    <button class="doc-btn doc-btn-share" onclick="docShare()">Share</button>
  </div>
</div>

{# ── TAB BAR ── #}
<div class="tabs-bar">
  <div class="tab active" data-tab="doc-document">Document</div>

  {% if images and images.length %}
    <div class="tab" data-tab="doc-images">Images</div>
  {% endif %}

  <div class="tab" data-tab="doc-source">Source</div>

  {% set hasSoldiers = false %}
  {% if author %}{% set hasSoldiers = true %}{% endif %}
  {% if contains and contains.length %}{% set hasSoldiers = true %}{% endif %}
  {% if tagged and tagged.length %}{% set hasSoldiers = true %}{% endif %}
  {% if hasSoldiers %}
    <div class="tab" data-tab="doc-soldiers">Soldiers</div>
  {% endif %}
</div>

{# ── TAB: DOCUMENT ── #}
<div class="tab-content" id="tab-doc-document">
  {% if content and content | trim %}
    <div class="doc-body">
      {{ content | safe }}
    </div>
  {% else %}
    <div class="tab-empty">
      No transcript available for this document.<br>
      <a href="/contribute/">Have a transcription to contribute? →</a>
    </div>
  {% endif %}
</div>

{# ── TAB: IMAGES ── #}
{% if images and images.length %}
<div class="tab-content" id="tab-doc-images" style="display:none">

  <script>
    var DOC_IMAGE_SLIDES = [
      {% for img in images %}
      {
        src: "{{ img.src }}",
        caption: {{ (img.caption or img.filename or "") | dump | safe }},
        credit: {{ (img.credit or "") | dump | safe }},
        date: {{ (img.date or "") | dump | safe }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ];
  </script>

  <div class="photo-grid">
    {% for img in images %}
      <div class="photo-card" onclick="lbOpen({{ loop.index0 }}, DOC_IMAGE_SLIDES)">
        <img src="{{ img.src }}" alt="{{ img.caption if img.caption else img.filename }}" loading="lazy">
        <div class="photo-overlay">
          <div class="photo-cap-text">{{ img.caption if img.caption else img.filename }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── TAB: SOURCE ── #}
<div class="tab-content" id="tab-doc-source" style="display:none">
  <div class="doc-meta-table">

    <div class="dmt-row">
      <div class="dmt-label">Type</div>
      <div class="dmt-value">{{ type | capitalize }}</div>
    </div>

    <div class="dmt-row">
      <div class="dmt-label">Date</div>
      <div class="dmt-value">
        {% if doc_date %}{{ doc_date }}{% else %}<span class="dim">Unknown</span>{% endif %}
        {% if not date_known %}<span class="doc-badge doc-badge-pending">Date uncertain</span>{% endif %}
      </div>
    </div>

    {% if source %}
    <div class="dmt-row">
      <div class="dmt-label">Source</div>
      <div class="dmt-value">{{ source }}</div>
    </div>
    {% endif %}

    {% if event %}
    <div class="dmt-row">
      <div class="dmt-label">Event</div>
      <div class="dmt-value">
        <a href="/events/{{ event }}/" class="doc-hero-link">{{ event }}</a>
      </div>
    </div>
    {% endif %}

    <div class="dmt-row">
      <div class="dmt-label">Status</div>
      <div class="dmt-value">{{ status | capitalize }}</div>
    </div>

  </div>
</div>

{# ── TAB: SOLDIERS ── #}
{% if hasSoldiers %}
<div class="tab-content" id="tab-doc-soldiers" style="display:none">

  {# ── Author ── #}
  {% if author %}
    <div class="section-header">
      <div class="section-title" style="font-size:13px;">Author</div>
      <div class="section-rule"></div>
    </div>
    <div class="alongside-grid" style="margin-bottom:24px;">
      {% for s in collections.soldiers %}
        {% if s.data.slug == author %}
          <div class="alongside-card">
            <a href="/soldiers/{{ author }}/" style="text-decoration:none;">
              <div class="alongside-photo">
                {% if s.data.profile_photo %}
                  <img src="/soldiers/{{ author }}/photos/profile/{{ s.data.profile_photo }}"
                       alt="{{ s.data.first_name }} {{ s.data.last_name }}"
                       style="width:100%;height:100%;object-fit:cover;"
                       onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                  <span style="display:none">{{ s.data.first_name[0] }}{{ s.data.last_name[0] }}</span>
                {% else %}
                  {{ s.data.first_name[0] }}{{ s.data.last_name[0] }}
                {% endif %}
              </div>
            </a>
            <div class="alongside-name">
              <a href="/soldiers/{{ author }}/" style="color:inherit;text-decoration:none;">
                {{ s.data.first_name }} {{ s.data.last_name }}
              </a>
            </div>
            <div class="alongside-meta">{{ s.data.platoon }}{% if s.data.arrived %} · {{ s.data.arrived }}–{{ s.data.departed }}{% endif %}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  {# ── Contains (explicitly referenced) ── #}
  {% if contains and contains.length %}
    <div class="section-header" {% if author %}style="margin-top:8px;"{% endif %}>
      <div class="section-title" style="font-size:13px;">Referenced</div>
      <div class="section-rule"></div>
      <div class="section-meta">{{ contains.length }} Soldier{% if contains.length != 1 %}s{% endif %}</div>
    </div>
    <div class="alongside-grid" style="margin-bottom:24px;">
      {% for soldierSlug in contains %}
        {% for s in collections.soldiers %}
          {% if s.data.slug == soldierSlug %}
            <div class="alongside-card">
              <a href="/soldiers/{{ soldierSlug }}/" style="text-decoration:none;">
                <div class="alongside-photo">
                  {% if s.data.profile_photo %}
                    <img src="/soldiers/{{ soldierSlug }}/photos/profile/{{ s.data.profile_photo }}"
                         alt="{{ s.data.first_name }} {{ s.data.last_name }}"
                         style="width:100%;height:100%;object-fit:cover;"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                    <span style="display:none">{{ s.data.first_name[0] }}{{ s.data.last_name[0] }}</span>
                  {% else %}
                    {{ s.data.first_name[0] }}{{ s.data.last_name[0] }}
                  {% endif %}
                </div>
              </a>
              <div class="alongside-name">
                <a href="/soldiers/{{ soldierSlug }}/" style="color:inherit;text-decoration:none;">
                  {{ s.data.first_name }} {{ s.data.last_name }}
                </a>
              </div>
              <div class="alongside-meta">{{ s.data.platoon }}</div>
            </div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  {% endif %}

  {# ── Tagged (also present) ── #}
  {% if tagged and tagged.length %}
    <div class="section-header" {% if author or (contains and contains.length) %}style="margin-top:8px;"{% endif %}>
      <div class="section-title" style="font-size:13px;">Also present</div>
      <div class="section-rule"></div>
      <div class="section-meta">{{ tagged.length }} Soldier{% if tagged.length != 1 %}s{% endif %}</div>
    </div>
    <div class="alongside-grid">
      {% for soldierSlug in tagged %}
        {% for s in collections.soldiers %}
          {% if s.data.slug == soldierSlug %}
            <div class="alongside-card">
              <a href="/soldiers/{{ soldierSlug }}/" style="text-decoration:none;">
                <div class="alongside-photo">
                  {% if s.data.profile_photo %}
                    <img src="/soldiers/{{ soldierSlug }}/photos/profile/{{ s.data.profile_photo }}"
                         alt="{{ s.data.first_name }} {{ s.data.last_name }}"
                         style="width:100%;height:100%;object-fit:cover;"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                    <span style="display:none">{{ s.data.first_name[0] }}{{ s.data.last_name[0] }}</span>
                  {% else %}
                    {{ s.data.first_name[0] }}{{ s.data.last_name[0] }}
                  {% endif %}
                </div>
              </a>
              <div class="alongside-name">
                <a href="/soldiers/{{ soldierSlug }}/" style="color:inherit;text-decoration:none;">
                  {{ s.data.first_name }} {{ s.data.last_name }}
                </a>
              </div>
              <div class="alongside-meta">{{ s.data.platoon }}</div>
            </div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endif %}

{% include "partials/footer.njk" %}

</main>

{# ── LIGHTBOX (reuse site-wide component) ── #}
<div class="lightbox" id="lightbox" onclick="lbClose(event)">
  <div class="lb-inner">
    <button class="lb-close" onclick="lbClose()">✕ CLOSE</button>
    <img id="lb-img" src="" alt="">
    <div class="lb-cap">
      <div class="lb-cap-meta">
        <span id="lb-cap-date"></span>
        <span id="lb-counter"></span>
      </div>
      <p id="lb-cap-p"></p>
      <small id="lb-cap-s"></small>
    </div>
    <div class="lb-nav">
      <button id="lb-prev" class="lb-arrow" onclick="event.stopPropagation();lbPrev()">← PREV</button>
      <button id="lb-next" class="lb-arrow" onclick="event.stopPropagation();lbNext()">NEXT →</button>
    </div>
  </div>
</div>

<div class="toast" id="toastEl"></div>

<script src="/assets/js/main.js"></script>

<script>
document.querySelectorAll('.tab').forEach(function(tab) {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.tab-content').forEach(function(c) { c.style.display = 'none'; });
    tab.classList.add('active');
    var target = document.getElementById('tab-' + tab.dataset.tab);
    if (target) target.style.display = 'block';
  });
});

function docShare() {
  var url = window.location.href;
  var title = {{ title | dump | safe }};
  if (navigator.share) {
    navigator.share({ title: title, url: url });
  } else {
    navigator.clipboard.writeText(url).then(function() {
      var toast = document.getElementById('toastEl');
      if (toast) {
        toast.textContent = 'Link copied';
        toast.classList.add('show');
        setTimeout(function() { toast.classList.remove('show'); }, 2000);
      }
    });
  }
}
</script>

</body>
</html>
