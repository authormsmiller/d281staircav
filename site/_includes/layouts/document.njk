<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — D Co. 2/8 CAV Archive</title>
<meta name="description" content="Archival document: {{ title }}. Contributed by {{ contributor_name }}.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

<header class="masthead">
  <a class="masthead-brand" href="/">
    <svg viewBox="0 0 26 31" fill="none" width="26" height="31">
      <path d="M13 2L2 6.5v12c0 8 5.5 12.5 11 13.5 5.5-1 11-5.5 11-13.5v-12L13 2z" fill="#F5C400" stroke="#C8A800" stroke-width="0.8"/>
      <path d="M2 6.5l22 0l-2.5 20" stroke="#0a0a08" stroke-width="9" fill="none"/>
      <ellipse cx="21" cy="10" rx="5.5" ry="6" fill="#0a0a08"/>
    </svg>
    <div class="brand-lines">
      <div class="brand-unit">D Co. 2/8 CAV</div>
      <div class="brand-sub">Angry Skipper Archive</div>
    </div>
  </a>
  <nav class="masthead-nav">
    <a class="nav-btn" href="/families/">For Families</a>
    <a class="nav-btn" href="/">Overview</a>
    <a class="nav-btn" href="/roster/">Roster</a>
    <a class="nav-btn cta" href="/contribute/">Contribute</a>
  </nav>
</header>

<div class="breadcrumb show">
  <a class="bc-link" href="/">Archive</a>
  <span class="bc-sep">›</span>
  <a class="bc-link" href="/soldiers/{{ contributor_slug }}/">{{ contributor_name }}</a>
  <span class="bc-sep">›</span>
  <span>{{ title }}</span>
</div>

<main>

{# ── DOCUMENT HEADER ── #}
<div class="section" style="padding-bottom:0;">
  <div class="doc-page-flag">{{ type }}</div>
  <h1 class="doc-page-title">{{ title }}</h1>
  <div class="doc-page-meta">
    {% if publication %}{{ publication }}{% endif %}
    {% if date_approx %} · {{ date_approx }}{% endif %}
    {% if location %} · {{ location }}{% endif %}
  </div>
  <div class="doc-page-contrib">
    Contributed by <a class="doc-page-contrib-link" href="/soldiers/{{ contributor_slug }}/">{{ contributor_name }}</a>
  </div>
  {% if contains and contains.length %}
    <div class="doc-page-tags">
      <span class="doc-page-tags-label">Soldiers mentioned:</span>
      {% for s in contains %}
        <a class="doc-page-tag" href="/soldiers/{{ s }}/">{{ s | replace("-", " ") | title }}</a>
      {% endfor %}
    </div>
  {% endif %}
</div>

{# ── DOCUMENT IMAGES ── #}
{% if images and images.length %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Original Document</div>
    <div class="section-rule"></div>
  </div>
  <div class="doc-image-stack">
    {% for img in images %}
      <figure class="doc-figure">
        <img
          class="doc-scan"
          src="/documents/{{ contributor_slug }}/{{ slug }}/{{ img.filename }}"
          alt="{{ img.caption }}"
          onclick="lbOpenSingle(this.src, '{{ img.caption }}')"
        >
        <figcaption class="doc-figcap">{{ img.caption }}</figcaption>
      </figure>
    {% endfor %}
  </div>
</div>
{% endif %}

{# ── TRANSCRIPTION ── #}
<div class="section">
  <div class="section-header">
    <div class="section-title">Transcription</div>
    <div class="section-rule"></div>
  </div>
  <div class="doc-transcription">
    {{ content | safe }}
  </div>
</div>

{# ── ARCHIVIST NOTES ── #}
{% if archivist_notes %}
<div class="section">
  <div class="section-header">
    <div class="section-title">Archivist Notes</div>
    <div class="section-rule"></div>
  </div>
  <div class="doc-archivist-notes">
    {{ archivist_notes }}
  </div>
</div>
{% endif %}

{# ── PROFILE CTA ── #}
<div class="prof-cta">
  <div>
    <h3>Do You Have Additional Information About This Document?</h3>
   <p>If you can identify the publication, confirm the date, or add context to this record, we would be grateful to hear from you.</p>

</div>
  <div class="prof-cta-btns">
    <a class="land-cta" href="/contribute/">Submit Information</a>
  </div>
</div>

<footer>
  <div class="footer-left">D Co. 2/8 CAV · Angry Skipper</div>
  <div class="footer-right">1st Cavalry Division (Airmobile) · Vietnam 1965–1972<br>Archive initiated April 2026 · Compiled by family</div>
</footer>

</main>

<div class="lightbox" id="lightbox" onclick="lbClose(event)">
  <div class="lb-inner">
    <button class="lb-close" onclick="lbClose()">✕ CLOSE</button>
    <img id="lb-img" src="" alt="">
    <div class="lb-cap">
      <div class="lb-cap-meta">
        <span id="lb-cap-date"></span>
        <span id="lb-counter"></span>
      </div>
      <p id="lb-cap-p"></p>
      <small id="lb-cap-s"></small>
    </div>
    <div class="lb-nav">
      <button id="lb-prev" class="lb-arrow" onclick="event.stopPropagation();lbPrev()">← PREV</button>
      <button id="lb-next" class="lb-arrow" onclick="event.stopPropagation();lbNext()">NEXT →</button>
    </div>
  </div>
</div>
<script src="/assets/js/main.js"></script>
</body>
</html>   