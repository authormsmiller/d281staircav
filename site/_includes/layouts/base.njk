<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
<meta name="description" content="{{ site.description }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

<!-- MASTHEAD -->
<header class="masthead">
  <a class="masthead-brand" href="/">
    <svg viewBox="0 0 26 31" fill="none" width="26" height="31">
      <path d="M13 2L2 6.5v12c0 8 5.5 12.5 11 13.5 5.5-1 11-5.5 11-13.5v-12L13 2z" fill="#F5C400" stroke="#C8A800" stroke-width="0.8"/>
      <path d="M2 6.5l22 0l-2.5 20" stroke="#0a0a08" stroke-width="9" fill="none"/>
      <ellipse cx="21" cy="10" rx="5.5" ry="6" fill="#0a0a08"/>
    </svg>
    <div class="brand-lines">
      <div class="brand-unit">D Co. 2/8 CAV</div>
      <div class="brand-sub">Angry Skipper Archive</div>
    </div>
  </a>
  <nav class="masthead-nav">
    <a class="nav-btn {% if page.url == '/families/' %}active{% endif %}" href="/families/">For Families</a>
    <a class="nav-btn {% if page.url == '/' %}active{% endif %}" href="/">Overview</a>
    <a class="nav-btn {% if page.url == '/roster/' %}active{% endif %}" href="/roster/">Roster</a>
    <a class="nav-btn {% if page.url == '/schema/' %}active{% endif %}" href="/schema/">Data Model</a>
    <a class="nav-btn cta" href="/contribute/">Contribute</a>
  </nav>
</header>

<!-- BREADCRUMB (shown on soldier profiles) -->
{% if breadcrumb %}
<div class="breadcrumb show">
  <a class="bc-link" href="/">Archive</a>
  <span class="bc-sep">›</span>
  <a class="bc-link" href="/roster/">Roster</a>
  <span class="bc-sep">›</span>
  <span>{{ breadcrumb }}</span>
</div>
{% endif %}

<!-- PAGE CONTENT -->
<main>
  {{ content | safe }}
</main>

<!-- TOAST (for form confirmations) -->
<div class="toast" id="toastEl"></div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" onclick="lbClose(event)">
  <div class="lb-inner">
    <button class="lb-close" onclick="lbClose()">✕ CLOSE</button>
    <img id="lb-img" src="" alt="">
    <div class="lb-cap">
      <p id="lb-cap-p"></p>
      <small id="lb-cap-s"></small>
    </div>
  </div>
</div>

<script src="/assets/js/main.js"></script>
</body>
</html>
