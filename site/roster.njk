---
layout: base.njk
title: Roster
permalink: /roster/
---

<div class="roster-masthead">
  <div>
    <div class="roster-hed">Cat Platoon<br><span>Roster</span></div>
    <div class="roster-stamp">Sensitive — Contact Info Redacted</div>
  </div>
  <div class="roster-deck">
    Compiled from unit records, the McGrew field calendar, ASA newsletters,
    and ongoing contact research. Research status indicates current confidence level.
    Personal contact details are maintained in restricted access only.
  </div>
</div>

<table class="rtable">
  <thead>
    <tr>
      <th>Name</th>
      <th>Known As</th>
      <th>Rank</th>
      <th>Platoon</th>
      <th>Service Dates</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>

    {# Auto-generated rows from soldier profile data files #}
    {% for soldier in collections.soldiers %}
      <tr onclick="window.location='{{ soldier.url }}'" style="cursor:pointer;">
        <td><div class="rname rname-link">{{ soldier.data.last_name }}, {{ soldier.data.first_name }}</div></td>
        <td>
          {% if soldier.data.nickname %}
            <span style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--dim);">"{{ soldier.data.nickname }}"</span>
          {% else %}
            <span style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--dim);">—</span>
          {% endif %}
        </td>
        <td><span class="rank-tag">{{ soldier.data.rank }}</span></td>
        <td>{{ soldier.data.platoon }}</td>
        <td style="font-family:'Space Grotesk',sans-serif;font-size:11px;letter-spacing:1px;">
          {{ soldier.data.arrived }} – {{ soldier.data.departed }}
        </td>
        <td>
          {% if soldier.data.status == "KIA" %}
            <span class="sdot sdot-kia">KIA</span>
          {% elif soldier.data.status == "Deceased" %}
            <span class="sdot sdot-kia">Deceased</span>
          {% else %}
            <span class="sdot sdot-ok">Profile Live</span>
          {% endif %}
        </td>
      </tr>
    {% endfor %}

    {# Rows from roster.json — edit that file to add/update soldiers #}
    {% for s in roster %}
      <tr>
        <td><div class="rname">{{ s.last_name }}, {{ s.first_name }}</div></td>
        <td>
          {% if s.nickname %}
            <span style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--dim);">"{{ s.nickname }}"</span>
          {% else %}
            <span style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--dim);">—</span>
          {% endif %}
        </td>
        <td>
          {% if s.rank %}
            <span class="rank-tag">{{ s.rank }}</span>
          {% else %}
            <span style="font-family:'Crimson Pro',serif;font-style:italic;font-size:14px;color:var(--dim);">—</span>
          {% endif %}
        </td>
        <td>{{ s.platoon }}</td>
        <td style="font-family:'Space Grotesk',sans-serif;font-size:11px;letter-spacing:1px;">{{ s.years }}</td>
        <td>
          {% if s.status == "deceased" %}
            <span class="sdot sdot-kia">{{ s.status_label }}</span>
          {% elif s.status == "confirmed" %}
            <span class="sdot sdot-ok">{{ s.status_label }}</span>
          {% else %}
            <span class="sdot sdot-unk">{{ s.status_label }}</span>
          {% endif %}
        </td>
      </tr>
    {% endfor %}

  </tbody>
</table>
